{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Current C++ File For Debug",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "$outputDir = Join-Path '${workspaceFolder}' '.tools\\cpp-run'; $compilerBin = Join-Path '${workspaceFolder}' '.tools\\w64devkit\\bin'; New-Item -ItemType Directory -Force -Path $outputDir | Out-Null; & (Join-Path $compilerBin 'g++.exe') '-B' $compilerBin '-std=c++17' '-g' '-Wall' '-Wextra' '-Wpedantic' '-fdebug-prefix-map=${workspaceFolder}=C:/cpp_course' '${file}' '-o' (Join-Path $outputDir 'current.exe')"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "LANG": "en_US.UTF-8",
          "PATH": "${workspaceFolder}\\.tools\\w64devkit\\bin;${env:PATH}"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
